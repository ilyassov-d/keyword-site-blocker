{
  "manifest_version": 3,
  "name": "Keyword Site Blocker",
  "version": "1.0.0",
  "description": "Blocks websites whose URL contains user-defined keywords.",
  "permissions": ["storage", "webNavigation", "tabs"],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_title": "Keyword Blocker",
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
